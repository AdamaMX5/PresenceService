# PresenceService Konfiguration
AUTH_SERVICE_URL=https://auth.freischule.info
REDIS_URL=redis://presence-redis:6379

# CORS
# Kommaseparierte Liste erlaubter Origins (z.B. https://app.example.com,https://admin.example.com)
CORS_ORIGINS=https://your-frontend.example.com
# Erlaubte HTTP-Methoden, kommasepariert oder * für alle
CORS_METHODS=*
# Erlaubte HTTP-Header, kommasepariert oder * für alle
CORS_HEADERS=*
# Credentials erlauben (true/false)
CORS_ALLOW_CREDENTIALS=true
